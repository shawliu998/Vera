# Aletheia Docker compliance preset. Copy to .env, provision every host path
# below, then run docker compose. This is intentionally not a quick-start:
# Compose refuses to start until the encrypted vault, independent audit journal,
# key directory, and offline ClamAV definitions are explicitly supplied.

FRONTEND_PORT=3000
BACKEND_PORT=3001
# Docker-internal listener. docker-compose.yml publishes both host ports on
# 127.0.0.1 only; do not widen those published bindings without a security review.
ALETHEIA_BACKEND_HOST=0.0.0.0
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# Legacy Aletheia is retained only for explicit compatibility and migration
# work. The active Vera runtime keeps both surfaces off by default; only the
# exact lowercase value "true" enables a gate. Enabling routes can initialize
# Legacy route-owned database/runtime objects, so do not enable either flag in a
# normal Vera deployment.
VERA_ENABLE_LEGACY_ROUTES=false
VERA_ENABLE_LEGACY_RUNTIME=false

# Local Aletheia auth. single_user is easiest for a local workstation.
ALETHEIA_AUTH_MODE=single_user
ALETHEIA_LOCAL_USER_ID=local-user
ALETHEIA_LOCAL_USER_EMAIL=local@aletheia.internal
ALETHEIA_DEPLOYMENT_PRESET=compliance
ALETHEIA_REQUIRE_ENCRYPTED_VOLUME=true
# Set only after verifying FileVault/BitLocker/LUKS (or equivalent) on the host
# directory named by ALETHEIA_HOST_DATA_DIR. Never use this as a declaration.
ALETHEIA_ENCRYPTED_VOLUME_ATTESTED=false

# Required bind mounts for the compliance preset. Keep data and anchor journal
# on distinct operator-controlled storage; key files must be outside data.
ALETHEIA_HOST_DATA_DIR=/secure/aletheia/data
ALETHEIA_HOST_AUDIT_ANCHOR_DIR=/secure/aletheia/audit-anchors
ALETHEIA_HOST_SECRETS_DIR=/secure/aletheia/secrets
ALETHEIA_HOST_CLAMAV_DB_DIR=/secure/aletheia/clamav-db

# Application-layer encryption for Aletheia source documents and local exports.
# The desktop app defaults this to required and provisions a 32-byte key in the
# user's macOS Keychain; no Apple Developer account is needed for Keychain use.
# For a backend-only install, set required and choose exactly one independent
# key source. Never store the key below ALETHEIA_DATA_DIR or in source control.
ALETHEIA_APPLICATION_ENCRYPTION=required
ALETHEIA_MASTER_KEY_SOURCE=file
ALETHEIA_MASTER_KEY_FILE=/run/aletheia-secrets/aletheia-master-key
# Transitional migration only; required mode rejects old plaintext by default.
# ALETHEIA_ALLOW_LEGACY_PLAINTEXT_READ=false

ALETHEIA_DATABASE_ENCRYPTION=sqlcipher_required
ALETHEIA_DATABASE_KEY_SOURCE=file
ALETHEIA_DATABASE_KEY_FILE=/run/aletheia-secrets/aletheia-database-key

# Independent Ed25519 audit anchoring. Compose maps these fixed container paths
# from the host directories above. High assurance blocks all writes if anchoring
# becomes unhealthy; ordinary storage is still not automatically true WORM.
ALETHEIA_AUDIT_ANCHOR_ENABLED=true
ALETHEIA_AUDIT_ANCHOR_HIGH_ASSURANCE=true
# Supply this after retaining the previous signed head with an independent
# custodian; leave empty only during the documented initial journal bootstrap.
# ALETHEIA_AUDIT_ANCHOR_EXPECTED_HEAD_HASH=sha256:<independently-retained-head>

# Compose image includes /usr/bin/clamscan. Definition files are mounted
# read-only from ALETHEIA_HOST_CLAMAV_DB_DIR and must be kept current by a
# separate reviewed update process. Missing/stale/broken definitions block
# uploads rather than silently admitting files.
ALETHEIA_MALWARE_SCAN_MODE=required
# Compose maps this to ALETHEIA_HOST_CLAMAV_DB_DIR read-only.
ALETHEIA_CLAMAV_DATABASE_DIR=/var/lib/clamav
# ALETHEIA_AUDIT_ANCHOR_INTERVAL_MS=900000
# ALETHEIA_AUDIT_ANCHOR_EXPECTED_HEAD_HASH=sha256:<independently-retained-head>

# Optional loopback-only local model and durable worker. Leave the model name
# empty to keep execution disabled. Managed executables need an explicit
# canonical-path allowlist; model endpoints must resolve to loopback.
# ALETHEIA_LOCAL_MODEL_NAME=qwen3:8b
# ALETHEIA_LOCAL_MODEL_ID=default-local
# ALETHEIA_LOCAL_MODEL_ADAPTER=ollama
# ALETHEIA_LOCAL_MODEL_ENDPOINT=http://127.0.0.1:11434
# Required for openai-compatible adapters; Ollama discovers its sha256 digest.
# ALETHEIA_LOCAL_MODEL_REVISION=sha256-or-immutable-runtime-revision
# ALETHEIA_LOCAL_MODEL_CONTEXT_TOKENS=32768
# ALETHEIA_LOCAL_MODEL_MAX_OUTPUT_TOKENS=4096
# ALETHEIA_LOCAL_MODEL_CONCURRENCY=1
# ALETHEIA_LOCAL_MODEL_QUEUE_LIMIT=16
# To register multiple local models, use ALETHEIA_LOCAL_MODELS_JSON (maximum 16
# loopback-only definitions). Choose their roles in Settings: Litigation
# analysis for the calibrated high-capability model (for example sol), and
# Routine analysis for bounded, non-final local work (for example terra).
# ALETHEIA_LOCAL_MODELS_JSON=[{"id":"sol","adapter":"ollama","endpoint":"http://127.0.0.1:11434","model":"sol:latest","contextWindowTokens":32768,"maxOutputTokens":4096},{"id":"terra","adapter":"ollama","endpoint":"http://127.0.0.1:11434","model":"terra:latest","contextWindowTokens":8192,"maxOutputTokens":1024}]
# ALETHEIA_LOCAL_MODEL_AUTOSTART=false
# ALETHEIA_LOCAL_MODEL_EXECUTABLE_ALLOWLIST=/absolute/path/to/ollama
# ALETHEIA_LOCAL_MODEL_ENV_ALLOWLIST=
# ALETHEIA_DURABLE_WORKER_POLL_MS=500
# ALETHEIA_DURABLE_WORKER_HEARTBEAT_MS=1000

# Compliance deployments begin with a blank workspace; demo data must never be
# created beside client matters.
ALETHEIA_DEMO_SEED_ENABLED=false
ALETHEIA_DEMO_SEED_MODE=empty

# Optional local private-token mode. If used, set both values to the same token.
# ALETHEIA_AUTH_MODE=private_token
# ALETHEIA_PRIVATE_AUTH_TOKEN=replace-with-a-random-local-private-token
# NEXT_PUBLIC_ALETHEIA_PRIVATE_AUTH_TOKEN=replace-with-the-same-token-for-local-browser-only

# Optional operator-managed HMAC key for per-matter audit chains. If omitted,
# local mode creates an owner-only .data/aletheia/.audit-hmac-key.
# Generate with: openssl rand -hex 32
# ALETHEIA_AUDIT_HMAC_SECRET=replace-with-a-random-32-byte-hex-string

# Production external-source connector. Automatic capture remains disabled until
# this comma-separated HTTPS host allowlist is explicitly configured.
# ALETHEIA_EXTERNAL_SOURCE_ALLOWED_DOMAINS=www.gov.cn,example-registry.gov
# RATE_LIMIT_EXTERNAL_SOURCE_WINDOW_MINUTES=15
# RATE_LIMIT_EXTERNAL_SOURCE_MAX=20

# Vera Research Broker uses only provider-authorized API or MCP transports. The
# endpoint and allowed host are deployment configuration, while the provider
# token is entered into encrypted local storage from the desktop client. Do not
# add a vendor credential to this file.
# PKULaw MCP: copy the real service-id URL from the PKULaw application page;
# the allowlist must contain exactly the gateway host. A separately contracted
# enterprise JSON/API URL remains supported through the same variables.
# VERA_PKULAW_API_ENDPOINT=https://apim-gw.pkulaw.com/<service-id>/mcp
# VERA_PKULAW_API_ALLOWED_HOSTS=apim-gw.pkulaw.com
# VERA_PKULAW_API_CREDENTIAL_REF=pkulaw-local-credential
# Vera's current YuanDian adapter uses the documented REST API with X-API-Key.
# VERA_YUANDIAN_API_ENDPOINT=https://open.chineselaw.com
# VERA_YUANDIAN_API_ALLOWED_HOSTS=open.chineselaw.com
# VERA_YUANDIAN_API_CREDENTIAL_REF=yuandian-local-credential
# Vera has not verified a public supported machine interface for Wolters
# China. Leave these unset unless Wolters/the institution supplies a private
# endpoint and written
# content rights matching Vera's enterprise JSON contract. Never use a website,
# captured internal endpoint, member credential, or browser cookie.
# VERA_WOLTERS_API_ENDPOINT=
# VERA_WOLTERS_API_ALLOWED_HOSTS=
# VERA_WOLTERS_API_CREDENTIAL_REF=
# VERA_OFFICIAL_LEGAL_API_ENDPOINT=https://api.official.example/v1/legal
# VERA_OFFICIAL_LEGAL_API_ALLOWED_HOSTS=api.official.example
# These values expose local readiness only. They do not open Vera's code-owned
# retention/lineage gate or satisfy the deployment data-use-policy gate.

# Local-only signing secret for backend download URLs.
# Generate a stronger value with: openssl rand -hex 32
DOWNLOAD_SIGNING_SECRET=replace-with-a-random-32-byte-hex-string
