PORT=3001
NODE_ENV=development
ALETHEIA_BACKEND_HOST=127.0.0.1
FRONTEND_URL=http://localhost:3000

# HMAC key used to sign /download/:token URLs. Required at startup.
# Generate with: openssl rand -hex 32
# Use a dedicated secret not reused by any other subsystem.
DOWNLOAD_SIGNING_SECRET=replace-with-a-random-32-byte-hex-string

# Aletheia storage is always local SQLite + owner-only filesystem storage.
ALETHEIA_DATA_DIR=.data/aletheia
ALETHEIA_AUTH_MODE=single_user
# Workspace /api/v1 permits single_user only for an explicitly opted-in,
# non-production local process. Every Workspace auth mode also requires the
# TCP peer itself to be loopback; proxy headers and browser CORS do not count.
VERA_WORKSPACE_ALLOW_SINGLE_USER_DEV=true
ALETHEIA_LOCAL_USER_ID=local-user
ALETHEIA_LOCAL_USER_EMAIL=local@aletheia.internal
# Dual-control approval remains disabled unless distinct authenticated local
# principals are intentionally deployed. Do not enable this for one shared token.
ALETHEIA_MULTI_PRINCIPAL_ENABLED=false
# Principal bearer tokens are issued by the governance admin API, returned
# once, and stored only as SHA-256 hashes. Default lifetime is 8 hours.
# ALETHEIA_PRINCIPAL_TOKEN_TTL_SECONDS=28800
# Optional explicit first local governance administrator. Without this, the
# first matter owner becomes bootstrap admin only while no admin exists.
# ALETHEIA_BOOTSTRAP_ADMIN_PRINCIPAL_ID=local-user
## Development defaults below deliberately remain convenient. For a Docker or
## regulated backend deployment use the compliance section in
## ../.env.example; it fails closed until every custody prerequisite is real.
ALETHEIA_DEPLOYMENT_PRESET=standard
ALETHEIA_REQUIRE_ENCRYPTED_VOLUME=false
# Set true only after FileVault/BitLocker/LUKS or an equivalent encrypted volume is verified.
ALETHEIA_ENCRYPTED_VOLUME_ATTESTED=false
# AES-256-GCM envelope encryption for source documents and persisted exports.
# Backend-only deployments should change this to required and provide a 32-byte
# operator key using env or an owner-only file outside ALETHEIA_DATA_DIR.
ALETHEIA_APPLICATION_ENCRYPTION=disabled
# ALETHEIA_MASTER_KEY_SOURCE=env
# ALETHEIA_MASTER_KEY_BASE64=<openssl rand -base64 32>
# ALETHEIA_MASTER_KEY_SOURCE=file
# ALETHEIA_MASTER_KEY_FILE=/secure/operator/aletheia-master-key
# ALETHEIA_ALLOW_LEGACY_PLAINTEXT_READ=false
# Default node:sqlite metadata remains plaintext. sqlcipher_required activates
# the verified @signalapp/sqlcipher adapter and requires a separate 32-byte key.
# Existing databases need the offline migration in docs/sqlcipher_integration.md.
ALETHEIA_DATABASE_ENCRYPTION=metadata_plaintext
# ALETHEIA_DATABASE_KEY_SOURCE=env
# ALETHEIA_DATABASE_KEY_BASE64=<openssl rand -base64 32>
# ALETHEIA_DATABASE_KEY_SOURCE=file
# ALETHEIA_DATABASE_KEY_FILE=/secure/operator/aletheia-database-key
# Independent Ed25519 audit anchor journal. Directory and private key must be
# outside ALETHEIA_DATA_DIR; high_assurance blocks writes after anchor failure.
ALETHEIA_AUDIT_ANCHOR_ENABLED=false
ALETHEIA_AUDIT_ANCHOR_HIGH_ASSURANCE=false
# ALETHEIA_AUDIT_ANCHOR_DIR=/Volumes/AletheiaAnchors/journal
# ALETHEIA_AUDIT_ANCHOR_PRIVATE_KEY_FILE=/secure/operator/anchor-private.pem
# ALETHEIA_AUDIT_ANCHOR_PUBLIC_KEY_FILE=/secure/operator/anchor-public.pem
# ALETHEIA_AUDIT_ANCHOR_INTERVAL_MS=900000
# ALETHEIA_AUDIT_ANCHOR_EXPECTED_HEAD_HASH=sha256:<independently-retained-head>
# Upload malware policy. Local development may explicitly choose disabled;
# compliance mode requires required and validates the scanner at startup.
ALETHEIA_MALWARE_SCAN_MODE=disabled
# ALETHEIA_CLAMAV_PATH=/usr/bin/clamscan
# ALETHEIA_CLAMAV_DATABASE_DIR=/var/lib/clamav
# Optional operator-managed audit-chain key. Otherwise local mode creates
# ALETHEIA_DATA_DIR/.audit-hmac-key with owner-only permissions.
# ALETHEIA_AUDIT_HMAC_SECRET=replace-with-a-random-32-byte-hex-string
# Optional local/private single-tenant auth:
# ALETHEIA_AUTH_MODE=private_token
# ALETHEIA_PRIVATE_AUTH_TOKEN=replace-with-a-random-local-private-token
ALETHEIA_RETRIEVAL_MODE=keyword
ALETHEIA_SEMANTIC_INDEX_ENABLED=false
ALETHEIA_SEMANTIC_INDEX_DRIVER=disabled
ALETHEIA_SEMANTIC_INDEX_DIR=.data/aletheia/index/semantic-local
# Controlled legal research sources. These variables configure only a
# vendor-issued HTTPS API/MCP endpoint and its exact host allowlist. Enter the
# credential through Vera's local provider control, where it is encrypted at
# rest; do not put the credential itself in this file. A missing endpoint,
# allowlist, or local credential leaves the Research Broker unavailable.
# PKULaw MCP: copy the real service-id URL from the PKULaw application page;
# the allowlist must contain exactly the gateway host. A separately contracted
# enterprise JSON/API URL remains supported through the same variables.
# VERA_PKULAW_API_ENDPOINT=https://apim-gw.pkulaw.com/<service-id>/mcp
# VERA_PKULAW_API_ALLOWED_HOSTS=apim-gw.pkulaw.com
# VERA_PKULAW_API_CREDENTIAL_REF=pkulaw-local-credential
# Vera's current YuanDian adapter uses the documented REST API with X-API-Key.
# VERA_YUANDIAN_API_ENDPOINT=https://open.chineselaw.com
# VERA_YUANDIAN_API_ALLOWED_HOSTS=open.chineselaw.com
# VERA_YUANDIAN_API_CREDENTIAL_REF=yuandian-local-credential
# Vera has not verified a public supported machine interface for Wolters
# China. Leave these unset unless Wolters/the institution supplies a private
# endpoint and written
# content rights matching Vera's enterprise JSON contract. Never use a website,
# captured internal endpoint, member credential, or browser cookie.
# VERA_WOLTERS_API_ENDPOINT=
# VERA_WOLTERS_API_ALLOWED_HOSTS=
# VERA_WOLTERS_API_CREDENTIAL_REF=
# Public official-source APIs use the same bounded JSON contract but no vendor
# credential. They remain unavailable unless both values are configured.
# VERA_OFFICIAL_LEGAL_API_ENDPOINT=https://api.official.example/v1/legal
# VERA_OFFICIAL_LEGAL_API_ALLOWED_HOSTS=api.official.example
# These values expose local readiness only. They do not open Vera's code-owned
# retention/lineage gate or satisfy the deployment data-use-policy gate.
# Naming a model enables the persistent single-process durable worker. The
# endpoint is validated as loopback-only; clients cannot override it per run.
# ALETHEIA_LOCAL_MODEL_NAME=qwen3:8b
# ALETHEIA_LOCAL_MODEL_ID=default-local
# ALETHEIA_LOCAL_MODEL_ADAPTER=ollama
# ALETHEIA_LOCAL_MODEL_ENDPOINT=http://127.0.0.1:11434
# Required for openai-compatible adapters; Ollama discovers its sha256 digest.
# ALETHEIA_LOCAL_MODEL_REVISION=sha256-or-immutable-runtime-revision
# ALETHEIA_LOCAL_MODEL_CONTEXT_TOKENS=32768
# ALETHEIA_LOCAL_MODEL_MAX_OUTPUT_TOKENS=4096
# ALETHEIA_LOCAL_MODEL_CONCURRENCY=1
# ALETHEIA_LOCAL_MODEL_QUEUE_LIMIT=16
# ALETHEIA_LOCAL_MODEL_REQUEST_TIMEOUT_MS=120000
# ALETHEIA_DURABLE_WORKER_POLL_MS=500
# ALETHEIA_DURABLE_WORKER_HEARTBEAT_MS=1000
# Upload limits remain 100 MB/file and 100 files/batch. Temporary files are
# automatically removed after this TTL (minimum 1 hour; default 24 hours).
# ALETHEIA_UPLOAD_TEMP_TTL_MS=86400000

# Content disarm/reconstruction is a separate stage after ClamAV. Disabled is
# honest: no file is described as sanitized. required fails closed unless a
# realpath-allowlisted LibreOffice and verified no-network isolator are present.
# Persisting a sanitized derivative also requires ALETHEIA_APPLICATION_ENCRYPTION=required
# so the authoritative original is never stored as plaintext.
ALETHEIA_CDR_MODE=disabled
# ALETHEIA_CDR_LIBREOFFICE_PATH=/Applications/LibreOffice.app/Contents/MacOS/soffice
# ALETHEIA_CDR_EXECUTABLE_ALLOWLIST=/Applications/LibreOffice.app/Contents/MacOS/soffice
# ALETHEIA_CDR_TIMEOUT_MS=120000
# ALETHEIA_CDR_MAX_OUTPUT_BYTES=209715200

# Backward-compatible aliases accepted by the backend:
# ALET_HEIA_DATA_DIR=.data/aletheia
# ALET_HEIA_AUTH_MODE=single_user
