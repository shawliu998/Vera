{
  "name": "aletheia-backend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "dev:aletheia:local": "tsx src/scripts/aletheiaLocalLauncher.ts",
    "mcp:aletheia": "tsx src/mcp/aletheiaServer.ts",
    "package:aletheia:local": "tsx src/scripts/aletheiaPackageLocal.ts",
    "test:aletheia:package": "ALETHEIA_PACKAGE_STRICT=true tsx src/scripts/aletheiaPackageLocal.ts",
    "check:aletheia:preflight": "tsx src/scripts/aletheiaPrivatePreflight.ts",
    "start": "node dist/index.js",
    "seed:aletheia:ui-smoke": "tsx src/scripts/aletheiaSeedUiSmoke.ts",
    "check:aletheia:operator": "tsx src/scripts/aletheiaOperatorHealth.ts",
    "check:aletheia:doctor": "ALETHEIA_STORAGE_DRIVER=local ALETHEIA_AUTH_MODE=single_user tsx src/scripts/aletheiaLocalDoctor.ts",
    "check:aletheia:backup": "ALETHEIA_STORAGE_DRIVER=local ALETHEIA_AUTH_MODE=single_user tsx src/scripts/aletheiaBackupManifest.ts",
    "check:aletheia:restore": "ALETHEIA_STORAGE_DRIVER=local ALETHEIA_AUTH_MODE=single_user tsx src/scripts/aletheiaRestorePreflight.ts",
    "check:aletheia:privacy": "tsx src/scripts/aletheiaPrivacyPreflight.ts",
    "check:aletheia:ops-readiness": "tsx src/scripts/aletheiaOpsReadinessAudit.ts",
    "check:aletheia:source-provenance": "tsx src/scripts/aletheiaSourceProvenanceAudit.ts",
    "check:aletheia:knowledge-governance": "tsx src/scripts/aletheiaKnowledgeGovernanceAudit.ts",
    "check:aletheia:audit-workbench": "tsx src/scripts/aletheiaAuditWorkbenchAudit.ts",
    "check:aletheia:tool-policy": "tsx src/scripts/aletheiaToolPolicyAudit.ts",
    "check:aletheia:approval-policy": "tsx src/scripts/aletheiaApprovalPolicyAudit.ts",
    "check:aletheia:matter-isolation": "tsx src/scripts/aletheiaMatterIsolationAudit.ts",
    "check:aletheia:run-trace": "tsx src/scripts/aletheiaRunTraceAudit.ts",
    "check:aletheia:evidence": "tsx src/scripts/aletheiaReleaseEvidence.ts",
    "check:aletheia:audit-integrity": "ALETHEIA_STORAGE_DRIVER=local ALETHEIA_AUTH_MODE=single_user tsx src/scripts/aletheiaAuditIntegrity.ts",
    "test:aletheia:completion": "tsx src/scripts/aletheiaCompletionAudit.ts",
    "test:aletheia:local": "tsx src/scripts/aletheiaLocalRegression.ts",
    "test:aletheia:batch-import-route": "tsx src/scripts/aletheiaBatchImportRouteAudit.ts",
    "test:aletheia:restore-drill": "tsx src/scripts/aletheiaRestoreDrill.ts",
    "test:aletheia:retrieval-eval": "tsx src/scripts/aletheiaRetrievalEval.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@aws-sdk/client-s3": "^3.787.0",
    "@aws-sdk/s3-request-presigner": "^3.787.0",
    "@google/genai": "^1.50.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@supabase/supabase-js": "^2.49.4",
    "cors": "^2.8.5",
    "docx": "^9.5.0",
    "dotenv": "^17.4.1",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "express-rate-limit": "^8.5.1",
    "fast-diff": "^1.3.0",
    "fast-xml-parser": "^5.7.1",
    "helmet": "^8.1.0",
    "jszip": "^3.10.1",
    "libreoffice-convert": "^1.6.0",
    "mammoth": "^1.9.0",
    "multer": "^1.4.5-lts.2",
    "pdfjs-dist": "^4.10.38",
    "resend": "^4.5.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.14.1",
    "prettier": "^3.8.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  },
  "license": "AGPL-3.0-only"
}
