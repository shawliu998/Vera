{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "ignoreDeprecations": "5.0",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node", "express", "cors", "multer"],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": [
    "src/index.ts",
    "src/routes/aletheia.ts",
    "src/routes/aletheiaLocalControl.ts",
    "src/routes/durableAgentRuns.ts",
    "src/routes/localGovernance.ts",
    "src/routes/localModels.ts",
    "src/lib/aletheia/**/*.ts",
    "src/lib/upload.ts",
    "src/lib/convert.ts",
    "src/middleware/auth.ts",
    "src/mcp/aletheiaServer.ts",
    "src/scripts/aletheia*.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
